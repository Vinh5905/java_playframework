# Full project routes - tất cả 8 tuần
GET     /health                         controllers.AccountController.health()

# Accounts
GET     /api/accounts/current           controllers.AccountController.current()
GET     /api/accounts                   controllers.AccountController.list()
POST    /api/accounts/switch/:id        controllers.AccountController.switchTo(id: Long)

# Presence
GET     /api/presence                   controllers.AccountController.presence()

# Conversations & Messages
GET     /api/conversations                                  controllers.ConversationController.list(accountId: Long ?= 1)
GET     /api/conversations/:convId/messages                 controllers.MessageController.getMessages(convId: String, limit: Int ?= 20)
POST    /api/conversations/:convId/messages                 controllers.MessageController.sendMessage(convId: String, request: Request)

# Global chat history
GET     /api/global/messages            controllers.GlobalChatController.history(limit: Int ?= 50)

# Settings
GET     /api/settings                   controllers.SettingsController.getSettings(userId: Long ?= 1)
PATCH   /api/settings                   controllers.SettingsController.updateSetting(userId: Long ?= 1, request: Request)

# WebSocket
GET     /ws/chat                        controllers.WebSocketController.chat()
GET     /ws/global                      controllers.GlobalChatController.join()
